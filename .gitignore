# Virtual environments (all subprojects)
.venv/
venv/
env/

# Python caches
__pycache__/
*.pyc
*.pyo

# OS junk
.DS_Store
.DS_store

# ---------------------------------------------------------------------------
# Oversized data in imported subprojects (kept out of git; not regenerable here)
# ---------------------------------------------------------------------------

# MatlabFunctions: multi-GB MATLAB recordings
MatlabFunctions/**/*.mat

# Groschner2022 dataset: hundreds of MB to multi-GB raw data
Groschner2022_multiplication/**/*.csv
Groschner2022_multiplication/**/*.npy
Groschner2022_multiplication/**/*.npz

# ---------------------------------------------------------------------------
# temporal_filtering: FAFB connectome large regenerable data
# (rebuild via build_network.py / build_all.py). Full-disc network.json are
# 80-160 MB; keep only the small cropped extent deliverables.
# ---------------------------------------------------------------------------
temporal_filtering/Connectome/**/network.json
!temporal_filtering/Connectome/**/*_extent2_col/network.json
temporal_filtering/Connectome/**/connections.csv.gz
temporal_filtering/**/.filter_cache
temporal_filtering/Connectome/**/download/connections_princeton.csv.gz

